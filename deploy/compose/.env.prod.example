# Copy to .env.prod and fill in real values. NEVER commit .env.prod.

# ---- Secrets (rotate periodically; losing ENCRYPTION_KEY bricks stored
# provider API keys) ---------------------------------------------------------
ENCRYPTION_KEY=__GENERATE_WITH__python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=__GENERATE_WITH__openssl rand -hex 32

# ---- Postgres -------------------------------------------------------------
POSTGRES_USER=omniai
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=omniai

# ---- MinIO (S3-compatible object store) -----------------------------------
OBJECT_STORE_ACCESS_KEY=omniai-prod
OBJECT_STORE_SECRET_KEY=__CHANGE_ME_AT_LEAST_16_CHARS__
OBJECT_STORE_BUCKET=omniai
OBJECT_STORE_REGION=us-east-1

# ---- Bootstrap admin (created on first boot only) -------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=__CHANGE_ME_STRONG__

# ---- App config -----------------------------------------------------------
API_CORS_ORIGINS=https://app.example.com
RATE_LIMIT_PER_MINUTE=300
TENANT_MAX_DOCUMENTS=10000
TENANT_MAX_STORAGE_BYTES=53687091200

# ---- Reranker / OCR -------------------------------------------------------
# RERANKER_KIND options: paired | sentence-transformers
RERANKER_KIND=paired
RERANKER_MODEL=BAAI/bge-reranker-base

# OCR_KIND options: none | tesseract | ollama_vision
OCR_KIND=none

# ---- Ollama (host-side LLM/embedding) -------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_VISION_MODEL=llava

# ---- Frontend -------------------------------------------------------------
# Public host the frontend will use to reach the API. "/" works when nginx
# proxies /v1 to the api service inside the same compose project.
VITE_API_BASE=/
FRONTEND_PORT=8080

# ---- Workers --------------------------------------------------------------
WORKER_REPLICAS=2

# ---- OpenSearch heap (per node) ------------------------------------------
OPENSEARCH_HEAP=1g
