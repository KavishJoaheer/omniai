{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus"}],
  "title": "Omni-AI — API Overview",
  "uid": "omniai-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate (req/s)", "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_http_requests_total[2m]))", "legendFormat": "req/s", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate", "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_http_requests_total{status=~'5..'}[2m])) / sum(rate(omniai_http_requests_total[2m]))", "legendFormat": "error%", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "options": {"colorMode": "background", "thresholds": {"steps": [{"value":0,"color":"green"},{"value":0.01,"color":"yellow"},{"value":0.05,"color":"red"}]}}
    },
    {
      "id": 3, "type": "stat", "title": "P99 Latency", "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "targets": [{"expr": "histogram_quantile(0.99, sum(rate(omniai_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"colorMode": "background"}
    },
    {
      "id": 4, "type": "stat", "title": "Rate Limited (req/s)", "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_rate_limited_total[2m]))", "legendFormat": "rate-limited", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"colorMode": "background"}
    },
    {
      "id": 5, "type": "timeseries", "title": "Requests by Status", "gridPos": {"x":0,"y":4,"w":24,"h":8},
      "targets": [{"expr": "sum(rate(omniai_http_requests_total[2m])) by (status)", "legendFormat": "{{status}}", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6, "type": "timeseries", "title": "Latency Percentiles", "gridPos": {"x":0,"y":12,"w":24,"h":8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(omniai_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(omniai_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, sum(rate(omniai_http_request_duration_seconds_bucket[2m])) by (le))", "legendFormat": "p99"}
      ],
      "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
