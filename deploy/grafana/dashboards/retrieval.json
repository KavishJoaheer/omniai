{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus"}],
  "title": "Omni-AI — Retrieval Quality",
  "uid": "omniai-retrieval",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Retrievals / min", "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_retrieval_total[1m])) * 60", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}]
    },
    {
      "id": 2, "type": "stat", "title": "Rerank Enabled %", "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_retrieval_total{rerank='true'}[5m])) / sum(rate(omniai_retrieval_total[5m]))", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 3, "type": "timeseries", "title": "Retrieval Rate by Rerank Flag", "gridPos": {"x":0,"y":4,"w":24,"h":8},
      "targets": [{"expr": "sum(rate(omniai_retrieval_total[2m])) by (rerank)", "legendFormat": "rerank={{rerank}}", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    }
  ]
}
