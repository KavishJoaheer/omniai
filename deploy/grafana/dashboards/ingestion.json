{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus"}],
  "title": "Omni-AI — Ingestion Pipeline",
  "uid": "omniai-ingestion",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Documents Indexed (last hour)", "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(increase(omniai_documents_indexed_total{status='success'}[1h]))", "legendFormat": "indexed", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}]
    },
    {
      "id": 2, "type": "stat", "title": "Ingestion Error Rate", "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets": [{"expr": "sum(rate(omniai_documents_indexed_total{status='error'}[10m])) / (sum(rate(omniai_documents_indexed_total[10m])) + 0.001)", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "options": {"thresholds": {"steps": [{"value":0,"color":"green"},{"value":0.1,"color":"yellow"},{"value":0.2,"color":"red"}]}}
    },
    {
      "id": 3, "type": "timeseries", "title": "Document Index Rate by Status", "gridPos": {"x":0,"y":4,"w":24,"h":8},
      "targets": [{"expr": "sum(rate(omniai_documents_indexed_total[5m])) by (status)", "legendFormat": "{{status}}", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    }
  ]
}
