HTTP_PORT=9380
APP_ENV=development
APP_NAME=Omni-AI
API_CORS_ORIGINS=http://localhost:5173

# Database (Postgres in compose, sqlite for local-only dev)
DB_URL=postgresql+psycopg://omniai:omniai@localhost:5432/omniai
DB_ECHO=false
AUTO_CREATE_SCHEMA=false

# Cache / queue
REDIS_URL=redis://localhost:6379/0

# Object store (S3-compatible / MinIO; OBJECT_STORE_KIND=local for plain dev)
OBJECT_STORE_KIND=s3
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=omniai
OBJECT_STORE_SECRET_KEY=omniai-minio-dev
OBJECT_STORE_BUCKET=omniai
OBJECT_STORE_LOCAL_DIR=./.omniai-storage

# Ingestion limits + worker
UPLOAD_MAX_BYTES=104857600
WORKER_INLINE=false

# Search engine
SEARCH_KIND=opensearch
SEARCH_URL=http://localhost:9200

# LLM provider defaults (Ollama is auto-detected from this URL)
OLLAMA_BASE_URL=http://localhost:11434

# Bootstrap tenant + admin
BOOTSTRAP_TENANT_SLUG=local-dev
BOOTSTRAP_TENANT_NAME=Local Development Tenant
BOOTSTRAP_ADMIN_EMAIL=admin@omniai.local
BOOTSTRAP_ADMIN_PASSWORD=Admin12345!
BOOTSTRAP_ADMIN_DISPLAY_NAME=Local Admin

# Auth + secrets
AUTH_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production-32-bytes-min
SESSION_TTL_MINUTES=480
SESSION_COOKIE_NAME=omniai_session
REGISTRATION_OPEN=true
